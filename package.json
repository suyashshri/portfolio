{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"bun run dev:server\" \"bun run dev:client\"",
    "dev:client": "bun run --cwd client dev",
    "dev:server": "bun run --cwd server dev",
    "build": "bun run --cwd client build",
    "start": "bun run --cwd server start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
